<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 192" width="192" height="192">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#312e81"/>
      <stop offset="100%" stop-color="#1e1b4b"/>
    </linearGradient>
    <linearGradient id="fire" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#f59e0b"/>
      <stop offset="100%" stop-color="#ef4444"/>
    </linearGradient>
  </defs>
  <!-- Background -->
  <rect width="192" height="192" rx="40" fill="url(#bg)"/>
  <!-- Grid lines -->
  <g stroke="#6366f1" stroke-width="2" opacity="0.3">
    <line x1="64" y1="40" x2="64" y2="152"/>
    <line x1="128" y1="40" x2="128" y2="152"/>
    <line x1="32" y1="72" x2="160" y2="72"/>
    <line x1="32" y1="120" x2="160" y2="120"/>
  </g>
  <!-- Tiles -->
  <rect x="36" y="44" width="52" height="52" rx="8" fill="#818cf8" opacity="0.8"/>
  <text x="62" y="80" text-anchor="middle" fill="white" font-size="28" font-weight="900" font-family="Arial">B</text>
  <rect x="100" y="44" width="56" height="52" rx="8" fill="#818cf8" opacity="0.8"/>
  <text x="128" y="80" text-anchor="middle" fill="white" font-size="28" font-weight="900" font-family="Arial">C</text>
  <rect x="68" y="96" width="56" height="52" rx="8" fill="url(#fire)" opacity="0.9"/>
  <text x="96" y="132" text-anchor="middle" fill="white" font-size="28" font-weight="900" font-family="Arial">W</text>
  <!-- Sword -->
  <g transform="translate(140,130) rotate(-45)" opacity="0.6">
    <rect x="-2" y="-30" width="4" height="35" rx="1" fill="#fbbf24"/>
    <rect x="-8" y="2" width="16" height="4" rx="1" fill="#fbbf24"/>
  </g>
  <!-- Sparkle -->
  <circle cx="150" cy="50" r="3" fill="#fbbf24" opacity="0.8"/>
  <circle cx="42" cy="140" r="2" fill="#818cf8" opacity="0.6"/>
</svg>
